# Copy to .env (gitignored) and fill in real values.
# These are only read by scripts/release.js, never bundled into the app.

# Cloudflare R2 API token with Object Read & Write on the releases bucket.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# S3-compatible endpoint for your R2 account.
# Format: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Bucket name.
R2_BUCKET=tunnex-releases

# (Optional) Cloudflare Pages "Deploy hook" for the marketing site.
# Pages → your project → Settings → Builds & deployments → Deploy hooks.
# When set, scripts/release.js POSTs here after a successful upload so the
# /download page picks up the new version automatically.
CF_PAGES_DEPLOY_HOOK=
