# Copy to .env (gitignored) and fill in real values.
# These are only read by scripts/release.js, never bundled into the app.

# Cloudflare R2 API token with Object Read & Write on the releases bucket.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# S3-compatible endpoint for your R2 account.
# Format: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Bucket name.
R2_BUCKET=tunnex-releases

# (Optional) Cloudflare Pages "Deploy hook" for the marketing site.
# Pages → your project → Settings → Builds & deployments → Deploy hooks.
# When set, scripts/release.js POSTs here after a successful upload so the
# /download page picks up the new version automatically.
CF_PAGES_DEPLOY_HOOK=

# ── Windows code signing (SignPath Foundation — free for OSS projects) ────────
# Apply at: https://signpath.io/solutions/open-source-community
# Once approved, add these values to GitHub Actions secrets (repo → Settings →
# Secrets and variables → Actions) — do NOT put real values here.
SIGNPATH_API_TOKEN=
SIGNPATH_ORG_ID=

# ── macOS code signing + notarization (requires Apple Developer ID, $99/yr) ──
# Export your Developer ID Application cert as .p12, base64-encode it, and
# store the result in CSC_LINK. Generate an app-specific password at
# appleid.apple.com. Find your Team ID at developer.apple.com/account.
# Set these in Codemagic → App → Environment variables (mark as Secure).
CSC_LINK=
CSC_KEY_PASSWORD=
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=
