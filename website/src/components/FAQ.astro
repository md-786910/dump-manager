---
interface QA { q: string; a: string; }
interface Props { items: QA[]; }
const { items } = Astro.props;
---
<div class="card p-2">
  {items.map((item, i) => (
    <details class="group" open={i === 0}>
      <summary class="cursor-pointer list-none flex items-start justify-between gap-4 p-4 rounded-md hover:bg-[var(--color-bg-2)] transition-colors">
        <span class="font-medium text-[var(--color-text)]">{item.q}</span>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="shrink-0 text-[var(--color-text-faint)] mt-1.5 transition-transform group-open:rotate-180">
          <path d="M4 6l4 4 4-4"/>
        </svg>
      </summary>
      <div class="px-4 pb-4 pt-1 text-sm text-[var(--color-text-muted)] leading-relaxed">
        <Fragment set:html={item.a} />
      </div>
    </details>
  ))}
</div>
