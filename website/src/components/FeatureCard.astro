---
interface Props {
  icon: string;
  title: string;
  body: string;
}
const { icon, title, body } = Astro.props;
---
<div class="card card-glow p-6 transition-transform hover:-translate-y-0.5">
  <div class="w-9 h-9 rounded-md bg-[var(--color-accent-dim)] text-[var(--color-accent)] flex items-center justify-center mb-4">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-base font-semibold mb-1.5 tracking-tight">{title}</h3>
  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{body}</p>
</div>
