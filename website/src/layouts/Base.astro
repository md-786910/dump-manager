---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { detectScript } from '../lib/platforms';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Tunnex — Encrypted backups for the databases you actually run',
  description = 'A desktop app for encrypted Postgres & Mongo dumps from docker-compose VPSes, installed DBs, or any URI. No agents. No cloud.',
  ogImage = '/og.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site || 'https://tunnex.biz').toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0d0f13" />
    <meta name="google-site-verification" content="U740PSTgtSwbzTLFHrf2dYxlmnWrDj9d9NiN1tLXdF8" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site || 'https://tunnex.biz').toString()} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link rel="stylesheet" href="https://fonts.bunny.net/css?family=inter:400,500,600,700&display=swap" />

    <script is:inline set:html={detectScript}></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
