---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import DownloadCTA from '../components/DownloadCTA.astro';

const principles = [
  { title: 'Your data, your disk.', body: 'No cloud. No telemetry. No accounts. We have no servers that ever see your data and we never want to.' },
  { title: 'Open formats.', body: 'Dumps are plain pg_dump custom-format and mongodump archives. Readable by any tool. Tunnex is a workflow over open primitives, not a proprietary blob.' },
  { title: 'Real cryptography.', body: 'AES-256-GCM with a key generated by the OS keychain. No "we encrypted it with the password you set" hand-wave. No bring-your-own-key gymnastics either — the OS handles it.' },
  { title: 'Boring tech.', body: 'Electron, Node, OpenSSL, ssh2. The same stack your prod runs on. No experimental crypto, no novel protocols, no "we wrote our own ___."' },
];

const stack = [
  { name: 'Electron', detail: 'v33, latest stable' },
  { name: 'Node', detail: 'v20 LTS' },
  { name: 'ssh2', detail: 'Pure-JS SSH client, audited' },
  { name: 'electron-updater', detail: 'Delta updates with signed blockmaps' },
  { name: 'AES-256-GCM', detail: 'Via Node\'s OpenSSL bindings' },
  { name: 'safeStorage', detail: 'OS keychain (Keychain / DPAPI / libsecret)' },
];

const roadmap = [
  { title: 'Code-signed Windows + notarized macOS builds', status: 'Q2' },
  { title: 'MySQL / MariaDB support', status: 'Q2' },
  { title: 'Scheduled backups (per target, with retention)', status: 'Q3' },
  { title: 'Optional encrypted off-site sync (your S3 / R2 / B2)', status: 'Q3' },
];
---
<Base title="About — Tunnex" description="The story behind Tunnex, the principles that drive it, the tech stack under the hood, and the public roadmap.">
  <section class="hero-bg border-b border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto px-5 pt-20 pb-12 text-center">
      <p class="text-[var(--color-accent)] uppercase tracking-wider text-xs font-mono font-semibold mb-3">About</p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight mb-4">Built by people who&nbsp;lost a database once.</h1>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
        Tunnex exists because backups should be boring — and ours wasn't.
      </p>
    </div>
  </section>

  <Section title="The story" align="center">
    <div class="max-w-2xl mx-auto space-y-5 text-[var(--color-text-muted)] leading-relaxed text-base">
      <p>
        Most developers we know have a backup setup that works "most of the time."
        SSH into a server, run <code>pg_dump</code>, scp the file out, hope the
        version mismatch isn't fatal, hope they remembered the right database
        name. It is fine — right up until it isn't.
      </p>
      <p>
        We built Tunnex after a long string of small disasters: half-finished
        restores at 4 AM, dumps sitting unencrypted in <code>~/Downloads</code>,
        forgotten cron jobs that had silently stopped firing months ago, the
        cold sweat of realising the staging refresh you were "just about to do"
        was the last clean copy of production.
      </p>
      <p>
        We built it as a desktop app, not a SaaS, on purpose. Your dumps are
        your business. They shouldn't pass through someone else's servers — and
        they shouldn't require an account, a billing relationship, or a service
        you have to trust will exist next year.
      </p>
    </div>
  </Section>

  <Section eyebrow="Principles" title="What we will and won't do." id="principles">
    <div class="grid md:grid-cols-2 gap-5">
      {principles.map((p) => (
        <div class="card p-6">
          <h3 class="text-lg font-semibold tracking-tight mb-2">{p.title}</h3>
          <p class="text-[var(--color-text-muted)] leading-relaxed">{p.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Under the hood" title="The stack." id="stack" lead="No magic. Same tools your production runs on.">
    <div class="card p-2">
      {stack.map((s) => (
        <div class="flex items-baseline justify-between px-4 py-3 border-b border-[var(--color-border)]/60 last:border-b-0">
          <span class="font-medium">{s.name}</span>
          <span class="font-mono text-sm text-[var(--color-text-faint)]">{s.detail}</span>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Roadmap" title="What's next." id="roadmap" lead="Honest line items. No dates we'd regret making.">
    <div class="space-y-3">
      {roadmap.map((r) => (
        <div class="card flex items-center justify-between px-5 py-4">
          <span>{r.title}</span>
          <span class="text-xs font-mono uppercase tracking-wider px-2 py-1 rounded-full bg-[var(--color-bg-2)] border border-[var(--color-border)] text-[var(--color-text-muted)]">
            {r.status}
          </span>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Privacy" title="What we collect." id="privacy">
    <div class="card p-6 max-w-3xl text-[var(--color-text-muted)] leading-relaxed space-y-3">
      <p>
        <strong class="text-[var(--color-text)]">Nothing.</strong> The desktop app
        has no analytics, no error reporting, no telemetry. It does not phone home.
        Its only outbound connections are to <em>your</em> SSH servers and to its
        own update manifest on Cloudflare R2 (to check for new versions).
      </p>
      <p>
        This site uses <a href="https://www.cloudflare.com/web-analytics/" class="underline">Cloudflare Web Analytics</a>,
        which is cookie-less and counts page views in aggregate. We can see that
        <em>some</em> people visited <code>/download</code> last Tuesday. We
        cannot see who they are.
      </p>
    </div>
  </Section>

  <Section eyebrow="Contact" title="Get in touch." id="contact" align="center">
    <div class="max-w-md mx-auto text-center space-y-4">
      <p class="text-[var(--color-text-muted)]">
        Bug reports, feature requests, partnerships, or just hellos —
        all welcome.
      </p>
      <a href="mailto:hello@tunnex.biz" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-[var(--color-accent)] text-white font-medium hover:bg-[var(--color-accent)]/90 transition-colors">
        hello@tunnex.biz
      </a>
    </div>
  </Section>

  <Section id="license" align="center">
    <div class="max-w-md mx-auto text-center text-sm text-[var(--color-text-faint)]">
      <p>Tunnex is currently distributed under a closed-source license while the API stabilises. Source release planned post-1.0.</p>
    </div>
  </Section>

  <Section align="center">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight mb-4">Try the beta.</h2>
      <p class="text-[var(--color-text-muted)] mb-6">Free during beta, auto-updates, three OSes.</p>
      <DownloadCTA compact />
    </div>
  </Section>
</Base>
