---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import { getReleaseInfo, formatBytes, platformLabel, kindLabel, type Platform } from '../lib/releases';

const release = await getReleaseInfo();

// Group files by platform for the download grid.
const groups: Record<Platform, typeof release.files> = { mac: [], windows: [], linux: [] };
for (const f of release.files) groups[f.platform].push(f);

const platforms: Array<{ key: Platform; icon: string; install: string[] }> = [
  {
    key: 'mac',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M16.49 8.65c-.34-.06-2.86-.23-4.45 2.05-1.18 1.68-.83 4 .31 5.18.97 1.01 1.97 1.43 2.83 1.43 1.18 0 1.95-.43 2.74-.43.71 0 1.5.45 2.65.45 1.04 0 2.07-.4 3-1.66.55-.77 1.34-2.2 1.34-2.2-.16-.07-2.59-1.05-2.61-3.83-.02-2.31 1.89-3.46 1.97-3.51-1.05-1.55-2.69-1.78-3.26-1.79-1.41-.12-2.71.85-3.42.85-.72 0-1.83-.84-3.1-.81zM15.42 4.79c.71-.83 1.18-1.99 1.05-3.15-1.01.04-2.24.68-2.97 1.5-.66.72-1.23 1.9-1.07 3.03 1.13.09 2.28-.58 2.99-1.38z"/></svg>`,
    install: [
      '1. Open the .dmg.',
      '2. Drag Tunnex into Applications.',
      '3. On first launch, right-click → Open (unsigned beta).',
    ],
  },
  {
    key: 'windows',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M3 5.5L10.5 4.4v7.1H3V5.5zm0 13L10.5 19.6v-7.1H3v6zm8.5 1.2L21 21V12.5h-9.5v7.2zm0-15.3V11.5H21V3L11.5 4.4z"/></svg>`,
    install: [
      '1. Run the installer.',
      '2. SmartScreen warning → "More info" → "Run anyway".',
      '3. Choose install path → next → next → done.',
    ],
  },
  {
    key: 'linux',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12.504 0c-.155 0-.31.05-.434.15-.7.564-.952 1.66-.97 2.5-.018.84.123 1.583.165 1.79.04.21.04.32 0 .42-.04.1-.1.18-.21.31-.11.13-.24.27-.4.46-.18.21-.36.46-.5.74-.14.28-.24.59-.27.92-.04.46.06.91.23 1.34.17.43.41.84.66 1.22.25.38.52.74.74 1.08.22.34.4.66.51 1.01.11.35.15.74.04 1.14-.11.4-.34.81-.6 1.21-.26.4-.55.79-.79 1.16-.24.37-.43.72-.5 1.06-.07.34-.02.66.13.95.15.29.4.54.73.74.33.2.74.34 1.21.39.47.05.97.01 1.49-.09.52-.1 1.02-.27 1.5-.45.48-.18.92-.38 1.32-.55.4-.17.75-.32 1.04-.4.29-.08.53-.09.71-.03.18.06.32.18.42.34.1.16.16.36.2.55.04.19.07.36.1.5.06.27.13.45.25.55.12.1.27.13.46.07.19-.06.4-.19.62-.39.22-.2.45-.46.66-.78.21-.32.4-.7.54-1.12.14-.42.22-.88.21-1.36-.01-.48-.12-.96-.32-1.42-.2-.46-.5-.91-.83-1.34-.33-.43-.7-.84-1.02-1.24-.32-.4-.6-.79-.78-1.16-.18-.37-.27-.72-.21-1.07.06-.35.25-.69.51-1.03.26-.34.6-.69.88-1.05.28-.36.5-.74.61-1.13.11-.39.1-.78-.07-1.18-.17-.4-.5-.81-.92-1.22-.42-.41-.94-.83-1.49-1.21-.55-.38-1.13-.72-1.7-.97-.57-.25-1.13-.4-1.62-.43-.13-.01-.26-.02-.39-.02z"/></svg>`,
    install: [
      'AppImage: chmod +x Tunnex-*-x86_64.AppImage && ./Tunnex-*-x86_64.AppImage',
      '.deb: sudo dpkg -i Tunnex-*-amd64.deb (or use your package manager)',
    ],
  },
];
---
<Base title="Download Tunnex" description="Direct downloads of the latest Tunnex release for Windows, macOS, and Linux. Free during public beta.">
  <section class="hero-bg border-b border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto px-5 pt-20 pb-12 text-center">
      <p class="text-[var(--color-accent)] uppercase tracking-wider text-xs font-mono font-semibold mb-3">Download</p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight mb-3">
        Tunnex v{release.version}
      </h1>
      <p class="text-[var(--color-text-muted)] max-w-xl mx-auto">
        Free during beta. Auto-updates from this same source — install once and forget about versions.
      </p>
    </div>
  </section>

  <Section>
    <div class="grid lg:grid-cols-3 gap-5">
      {platforms.map((p) => (
        <div class="card card-glow p-6 flex flex-col">
          <div class="flex items-center gap-3 mb-4 text-[var(--color-accent)]">
            <Fragment set:html={p.icon} />
            <h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)]">{platformLabel(p.key)}</h2>
          </div>

          {groups[p.key].length ? (
            <div class="space-y-2 mb-5">
              {groups[p.key].map((f) => (
                <a
                  href={f.url}
                  class="flex items-center justify-between gap-3 p-3 rounded-md bg-[var(--color-bg-2)] hover:bg-[var(--color-bg-3)] transition-colors"
                >
                  <span class="min-w-0">
                    <span class="block text-sm font-medium truncate">{kindLabel(f.kind)}</span>
                    <span class="block text-xs text-[var(--color-text-faint)] font-mono">
                      {f.arch}{f.size ? ' · ' + formatBytes(f.size) : ''}
                    </span>
                  </span>
                  <span class="text-[var(--color-accent)]">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M8 2v10M4 8l4 4 4-4M2 14h12"/>
                    </svg>
                  </span>
                </a>
              ))}
            </div>
          ) : (
            <p class="text-sm text-[var(--color-text-faint)] mb-5 font-mono">
              No build for this platform in the current release.
            </p>
          )}

          <div class="mt-auto">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-faint)] mb-2">Install</h3>
            <ol class="space-y-1 text-xs text-[var(--color-text-muted)] font-mono leading-relaxed">
              {p.install.map((step) => <li>{step}</li>)}
            </ol>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Verify" title="Checksums" lead="Every file is published with a SHA-512 hash. Verify before running anything you download from the internet.">
    <div class="card overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-[var(--color-bg-2)] text-[var(--color-text-faint)] text-xs uppercase tracking-wider">
          <tr>
            <th class="text-left px-4 py-3 font-medium">File</th>
            <th class="text-left px-4 py-3 font-medium hidden sm:table-cell">Size</th>
            <th class="text-left px-4 py-3 font-medium">SHA-512</th>
          </tr>
        </thead>
        <tbody>
          {release.files.map((f) => (
            <tr class="border-t border-[var(--color-border)]/60">
              <td class="px-4 py-3 font-mono text-xs"><a href={f.url} class="hover:text-[var(--color-accent)] hover:underline break-all">{f.filename}</a></td>
              <td class="px-4 py-3 font-mono text-xs hidden sm:table-cell text-[var(--color-text-faint)]">{formatBytes(f.size)}</td>
              <td class="px-4 py-3 font-mono text-[10px] text-[var(--color-text-faint)] break-all max-w-xs">{f.sha512.slice(0, 32)}…</td>
            </tr>
          ))}
          {!release.files.length && (
            <tr><td colspan="3" class="px-4 py-6 text-center text-[var(--color-text-faint)] font-mono text-sm">No releases published yet.</td></tr>
          )}
        </tbody>
      </table>
    </div>
    <p class="mt-4 text-xs font-mono text-[var(--color-text-faint)]">
      Verify on Linux/macOS: <code class="bg-[var(--color-bg-2)] px-1.5 py-0.5 rounded">shasum -a 512 &lt;filename&gt;</code>
      &nbsp;·&nbsp; Windows: <code class="bg-[var(--color-bg-2)] px-1.5 py-0.5 rounded">CertUtil -hashfile &lt;filename&gt; SHA512</code>
    </p>
  </Section>
</Base>
