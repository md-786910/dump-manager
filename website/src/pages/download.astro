---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import { getReleaseInfo, formatBytes, platformLabel, kindLabel, type Platform } from '../lib/releases';

const release = await getReleaseInfo();

// Group files by platform for the download grid.
const groups: Record<Platform, typeof release.files> = { mac: [], windows: [], linux: [] };
for (const f of release.files) groups[f.platform].push(f);

const platforms: Array<{ key: Platform; icon: string; install: string[] }> = [
  {
    key: 'mac',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M16.49 8.65c-.34-.06-2.86-.23-4.45 2.05-1.18 1.68-.83 4 .31 5.18.97 1.01 1.97 1.43 2.83 1.43 1.18 0 1.95-.43 2.74-.43.71 0 1.5.45 2.65.45 1.04 0 2.07-.4 3-1.66.55-.77 1.34-2.2 1.34-2.2-.16-.07-2.59-1.05-2.61-3.83-.02-2.31 1.89-3.46 1.97-3.51-1.05-1.55-2.69-1.78-3.26-1.79-1.41-.12-2.71.85-3.42.85-.72 0-1.83-.84-3.1-.81zM15.42 4.79c.71-.83 1.18-1.99 1.05-3.15-1.01.04-2.24.68-2.97 1.5-.66.72-1.23 1.9-1.07 3.03 1.13.09 2.28-.58 2.99-1.38z"/></svg>`,
    install: [
      '1. Open the .dmg.',
      '2. Drag Tunnex into Applications.',
      '3. On first launch, right-click → Open (unsigned beta).',
    ],
  },
  {
    key: 'windows',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M3 5.5L10.5 4.4v7.1H3V5.5zm0 13L10.5 19.6v-7.1H3v6zm8.5 1.2L21 21V12.5h-9.5v7.2zm0-15.3V11.5H21V3L11.5 4.4z"/></svg>`,
    install: [
      '1. Run the installer.',
      '2. SmartScreen warning → "More info" → "Run anyway".',
      '3. Choose install path → next → next → done.',
    ],
  },
  {
    key: 'linux',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12.504 0c-.155 0-.31.05-.434.15-.7.564-.952 1.66-.97 2.5-.018.84.123 1.583.165 1.79.04.21.04.32 0 .42-.04.1-.1.18-.21.31-.11.13-.24.27-.4.46-.18.21-.36.46-.5.74-.14.28-.24.59-.27.92-.04.46.06.91.23 1.34.17.43.41.84.66 1.22.25.38.52.74.74 1.08.22.34.4.66.51 1.01.11.35.15.74.04 1.14-.11.4-.34.81-.6 1.21-.26.4-.55.79-.79 1.16-.24.37-.43.72-.5 1.06-.07.34-.02.66.13.95.15.29.4.54.73.74.33.2.74.34 1.21.39.47.05.97.01 1.49-.09.52-.1 1.02-.27 1.5-.45.48-.18.92-.38 1.32-.55.4-.17.75-.32 1.04-.4.29-.08.53-.09.71-.03.18.06.32.18.42.34.1.16.16.36.2.55.04.19.07.36.1.5.06.27.13.45.25.55.12.1.27.13.46.07.19-.06.4-.19.62-.39.22-.2.45-.46.66-.78.21-.32.4-.7.54-1.12.14-.42.22-.88.21-1.36-.01-.48-.12-.96-.32-1.42-.2-.46-.5-.91-.83-1.34-.33-.43-.7-.84-1.02-1.24-.32-.4-.6-.79-.78-1.16-.18-.37-.27-.72-.21-1.07.06-.35.25-.69.51-1.03.26-.34.6-.69.88-1.05.28-.36.5-.74.61-1.13.11-.39.1-.78-.07-1.18-.17-.4-.5-.81-.92-1.22-.42-.41-.94-.83-1.49-1.21-.55-.38-1.13-.72-1.7-.97-.57-.25-1.13-.4-1.62-.43-.13-.01-.26-.02-.39-.02z"/></svg>`,
    install: [
      'AppImage: chmod +x Tunnex-*-x86_64.AppImage && ./Tunnex-*-x86_64.AppImage',
      '.deb: sudo dpkg -i Tunnex-*-amd64.deb (or use your package manager)',
    ],
  },
];
---
<Base title="Download Tunnex" description="Direct downloads of the latest Tunnex release for Windows, macOS, and Linux. Free during public beta.">
  <section class="hero-bg border-b border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto px-5 pt-20 pb-12 text-center">
      <p class="text-[var(--color-accent)] uppercase tracking-wider text-xs font-mono font-semibold mb-3">Download</p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight mb-3">
        Tunnex v{release.version}
      </h1>
      <p class="text-[var(--color-text-muted)] max-w-xl mx-auto">
        Free during beta. Auto-updates from this same source — install once and forget about versions.
      </p>
    </div>
  </section>

  <!-- ── Quick Install + Downloads (single section, no double-gap) ──────── -->
  <Section eyebrow="Install" title="Get Tunnex on your machine">

    <!-- CLI install: all three platforms always visible -->
    <div class="grid sm:grid-cols-3 gap-4 mb-14">

      <!-- macOS -->
      <div data-os-card="mac" class="card p-4 flex flex-col gap-3 transition-all duration-150">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2 text-[var(--color-text-muted)]">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="shrink-0"><path d="M16.49 8.65c-.34-.06-2.86-.23-4.45 2.05-1.18 1.68-.83 4 .31 5.18.97 1.01 1.97 1.43 2.83 1.43 1.18 0 1.95-.43 2.74-.43.71 0 1.5.45 2.65.45 1.04 0 2.07-.4 3-1.66.55-.77 1.34-2.2 1.34-2.2-.16-.07-2.59-1.05-2.61-3.83-.02-2.31 1.89-3.46 1.97-3.51-1.05-1.55-2.69-1.78-3.26-1.79-1.41-.12-2.71.85-3.42.85-.72 0-1.83-.84-3.1-.81zM15.42 4.79c.71-.83 1.18-1.99 1.05-3.15-1.01.04-2.24.68-2.97 1.5-.66.72-1.23 1.9-1.07 3.03 1.13.09 2.28-.58 2.99-1.38z"/></svg>
            <span class="text-xs font-semibold uppercase tracking-wider">macOS</span>
          </div>
          <span data-os-badge="mac" class="hidden text-[10px] font-mono px-1.5 py-0.5 rounded bg-[var(--color-accent-dim)] text-[var(--color-accent)]">your OS</span>
        </div>
        <div class="flex items-center gap-2 rounded-md bg-[var(--color-bg-2)] border border-[var(--color-border)] px-3 py-2.5 font-mono text-xs">
          <span class="text-[var(--color-accent)] select-none shrink-0">$</span>
          <code class="flex-1 text-[var(--color-text)] min-w-0 truncate" id="cmd-mac">curl -fsSL https://tunnex.biz/install.sh | bash</code>
          <button onclick="copyCmd('cmd-mac', this)" aria-label="Copy" class="shrink-0 p-1 rounded text-[var(--color-text-faint)] hover:text-[var(--color-accent)] transition-colors">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="5" width="9" height="9" rx="1.5"/><path d="M11 5V3a1.5 1.5 0 0 0-1.5-1.5h-6A1.5 1.5 0 0 0 2 3v6A1.5 1.5 0 0 0 3.5 10.5H5"/></svg>
          </button>
        </div>
        <p class="text-[11px] text-[var(--color-text-faint)] font-mono leading-relaxed">Terminal · Apple Silicon &amp; Intel · installs to /Applications</p>
      </div>

      <!-- Linux -->
      <div data-os-card="linux" class="card p-4 flex flex-col gap-3 transition-all duration-150">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2 text-[var(--color-text-muted)]">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="shrink-0"><path d="M12.504 0c-.155 0-.31.05-.434.15-.7.564-.952 1.66-.97 2.5-.018.84.123 1.583.165 1.79.04.21.04.32 0 .42-.04.1-.1.18-.21.31-.11.13-.24.27-.4.46-.18.21-.36.46-.5.74-.14.28-.24.59-.27.92-.04.46.06.91.23 1.34.17.43.41.84.66 1.22.25.38.52.74.74 1.08.22.34.4.66.51 1.01.11.35.15.74.04 1.14-.11.4-.34.81-.6 1.21-.26.4-.55.79-.79 1.16-.24.37-.43.72-.5 1.06-.07.34-.02.66.13.95.15.29.4.54.73.74.33.2.74.34 1.21.39.47.05.97.01 1.49-.09.52-.1 1.02-.27 1.5-.45.48-.18.92-.38 1.32-.55.4-.17.75-.32 1.04-.4.29-.08.53-.09.71-.03.18.06.32.18.42.34.1.16.16.36.2.55.04.19.07.36.1.5.06.27.13.45.25.55.12.1.27.13.46.07.19-.06.4-.19.62-.39.22-.2.45-.46.66-.78.21-.32.4-.7.54-1.12.14-.42.22-.88.21-1.36-.01-.48-.12-.96-.32-1.42-.2-.46-.5-.91-.83-1.34-.33-.43-.7-.84-1.02-1.24-.32-.4-.6-.79-.78-1.16-.18-.37-.27-.72-.21-1.07.06-.35.25-.69.51-1.03.26-.34.6-.69.88-1.05.28-.36.5-.74.61-1.13.11-.39.1-.78-.07-1.18-.17-.4-.5-.81-.92-1.22-.42-.41-.94-.83-1.49-1.21-.55-.38-1.13-.72-1.7-.97-.57-.25-1.13-.4-1.62-.43-.13-.01-.26-.02-.39-.02z"/></svg>
            <span class="text-xs font-semibold uppercase tracking-wider">Linux</span>
          </div>
          <span data-os-badge="linux" class="hidden text-[10px] font-mono px-1.5 py-0.5 rounded bg-[var(--color-accent-dim)] text-[var(--color-accent)]">your OS</span>
        </div>
        <div class="flex items-center gap-2 rounded-md bg-[var(--color-bg-2)] border border-[var(--color-border)] px-3 py-2.5 font-mono text-xs">
          <span class="text-[var(--color-accent)] select-none shrink-0">$</span>
          <code class="flex-1 text-[var(--color-text)] min-w-0 truncate" id="cmd-linux">curl -fsSL https://tunnex.biz/install.sh | bash</code>
          <button onclick="copyCmd('cmd-linux', this)" aria-label="Copy" class="shrink-0 p-1 rounded text-[var(--color-text-faint)] hover:text-[var(--color-accent)] transition-colors">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="5" width="9" height="9" rx="1.5"/><path d="M11 5V3a1.5 1.5 0 0 0-1.5-1.5h-6A1.5 1.5 0 0 0 2 3v6A1.5 1.5 0 0 0 3.5 10.5H5"/></svg>
          </button>
        </div>
        <p class="text-[11px] text-[var(--color-text-faint)] font-mono leading-relaxed">.deb on Debian/Ubuntu · AppImage elsewhere · installs to ~/.local/bin</p>
      </div>

      <!-- Windows -->
      <div data-os-card="windows" class="card p-4 flex flex-col gap-3 transition-all duration-150">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2 text-[var(--color-text-muted)]">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="shrink-0"><path d="M3 5.5L10.5 4.4v7.1H3V5.5zm0 13L10.5 19.6v-7.1H3v6zm8.5 1.2L21 21V12.5h-9.5v7.2zm0-15.3V11.5H21V3L11.5 4.4z"/></svg>
            <span class="text-xs font-semibold uppercase tracking-wider">Windows</span>
          </div>
          <span data-os-badge="windows" class="hidden text-[10px] font-mono px-1.5 py-0.5 rounded bg-[var(--color-accent-dim)] text-[var(--color-accent)]">your OS</span>
        </div>
        <div class="flex items-center gap-2 rounded-md bg-[var(--color-bg-2)] border border-[var(--color-border)] px-3 py-2.5 font-mono text-xs">
          <span class="text-[var(--color-accent)] select-none shrink-0">PS&gt;</span>
          <code class="flex-1 text-[var(--color-text)] min-w-0 truncate" id="cmd-win">irm https://tunnex.biz/install.ps1 | iex</code>
          <button onclick="copyCmd('cmd-win', this)" aria-label="Copy" class="shrink-0 p-1 rounded text-[var(--color-text-faint)] hover:text-[var(--color-accent)] transition-colors">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="5" width="9" height="9" rx="1.5"/><path d="M11 5V3a1.5 1.5 0 0 0-1.5-1.5h-6A1.5 1.5 0 0 0 2 3v6A1.5 1.5 0 0 0 3.5 10.5H5"/></svg>
          </button>
        </div>
        <p class="text-[11px] text-[var(--color-text-faint)] font-mono leading-relaxed">PowerShell · downloads &amp; runs the NSIS installer · x64</p>
      </div>

    </div>

    <!-- copy button + OS highlight scripts -->
    <script is:inline>
      function copyCmd(id, btn) {
        var text = document.getElementById(id)?.textContent?.trim();
        if (!text || !navigator.clipboard) return;
        navigator.clipboard.writeText(text).then(function () {
          var orig = btn.innerHTML;
          btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 9 6 13 14 4"/></svg>';
          setTimeout(function () { btn.innerHTML = orig; }, 1800);
        });
      }
      // Highlight the user's own OS card + show "your OS" badge
      (function () {
        var os = document.documentElement.getAttribute('data-os') || 'linux';
        var card = document.querySelector('[data-os-card="' + os + '"]');
        if (card) card.classList.add('os-card-active');
        var badge = document.querySelector('[data-os-badge="' + os + '"]');
        if (badge) badge.classList.remove('hidden');
      })();
    </script>

    <!-- "or download manually" divider -->
    <div class="flex items-center gap-4 mb-10">
      <div class="flex-1 h-px bg-[var(--color-border)]"></div>
      <span class="text-xs text-[var(--color-text-faint)] font-mono uppercase tracking-wider shrink-0">or download manually</span>
      <div class="flex-1 h-px bg-[var(--color-border)]"></div>
    </div>

    <!-- manual download grid -->
    <div class="grid lg:grid-cols-3 gap-5">
      {platforms.map((p) => (
        <div class="card card-glow p-6 flex flex-col">
          <div class="flex items-center gap-3 mb-4 text-[var(--color-accent)]">
            <Fragment set:html={p.icon} />
            <h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)]">{platformLabel(p.key)}</h2>
          </div>

          {groups[p.key].length ? (
            <div class="space-y-2 mb-5">
              {groups[p.key].map((f) => (
                <a
                  href={f.url}
                  class="flex items-center justify-between gap-3 p-3 rounded-md bg-[var(--color-bg-2)] hover:bg-[var(--color-bg-3)] transition-colors"
                >
                  <span class="min-w-0">
                    <span class="block text-sm font-medium truncate">{kindLabel(f.kind)}</span>
                    <span class="block text-xs text-[var(--color-text-faint)] font-mono">
                      {f.arch}{f.size ? ' · ' + formatBytes(f.size) : ''}
                    </span>
                  </span>
                  <span class="text-[var(--color-accent)]">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M8 2v10M4 8l4 4 4-4M2 14h12"/>
                    </svg>
                  </span>
                </a>
              ))}
            </div>
          ) : (
            <div class="mb-5 flex items-start gap-3 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3">
              <svg class="mt-0.5 shrink-0 text-[var(--color-text-faint)]" width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="8" cy="8" r="6"/><path d="M8 5v3.5M8 11v.5"/>
              </svg>
              <div>
                <p class="text-sm font-medium text-[var(--color-text)]">Coming Soon</p>
                <p class="mt-0.5 text-xs text-[var(--color-text-faint)]">This platform build will be available in an upcoming release.</p>
              </div>
            </div>
          )}

          <div class="mt-auto">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-faint)] mb-2">Install</h3>
            <ol class="space-y-1 text-xs text-[var(--color-text-muted)] font-mono leading-relaxed">
              {p.install.map((step) => <li>{step}</li>)}
            </ol>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Verify" title="Checksums" lead="Every file is published with a SHA-512 hash. Verify before running anything you download from the internet.">
    <div class="card overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-[var(--color-bg-2)] text-[var(--color-text-faint)] text-xs uppercase tracking-wider">
          <tr>
            <th class="text-left px-4 py-3 font-medium">File</th>
            <th class="text-left px-4 py-3 font-medium hidden sm:table-cell">Size</th>
            <th class="text-left px-4 py-3 font-medium">SHA-512</th>
          </tr>
        </thead>
        <tbody>
          {release.files.map((f) => (
            <tr class="border-t border-[var(--color-border)]/60">
              <td class="px-4 py-3 font-mono text-xs"><a href={f.url} class="hover:text-[var(--color-accent)] hover:underline break-all">{f.filename}</a></td>
              <td class="px-4 py-3 font-mono text-xs hidden sm:table-cell text-[var(--color-text-faint)]">{formatBytes(f.size)}</td>
              <td class="px-4 py-3 font-mono text-[10px] text-[var(--color-text-faint)] break-all max-w-xs">{f.sha512.slice(0, 32)}…</td>
            </tr>
          ))}
          {!release.files.length && (
            <tr><td colspan="3" class="px-4 py-6 text-center text-[var(--color-text-faint)] font-mono text-sm">No releases published yet.</td></tr>
          )}
        </tbody>
      </table>
    </div>
    <p class="mt-4 text-xs font-mono text-[var(--color-text-faint)]">
      Verify on Linux/macOS: <code class="bg-[var(--color-bg-2)] px-1.5 py-0.5 rounded">shasum -a 512 &lt;filename&gt;</code>
      &nbsp;·&nbsp; Windows: <code class="bg-[var(--color-bg-2)] px-1.5 py-0.5 rounded">CertUtil -hashfile &lt;filename&gt; SHA512</code>
    </p>
  </Section>

  <style is:global>
    .os-card-active {
      border-color: rgba(59, 130, 246, 0.45);
      background: linear-gradient(180deg, rgba(59,130,246,0.07) 0%, var(--color-bg) 100%);
    }
  </style>
</Base>
