---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import ScreenshotFrame from '../components/ScreenshotFrame.astro';
import DownloadCTA from '../components/DownloadCTA.astro';

const sections = [
  {
    id: 'tree',
    title: 'The tree view',
    eyebrow: 'Inventory',
    body: 'Servers (LOCAL and VPS, grouped), compose projects, services, databases — all in one sidebar. Click any node to drill in. Search across everything you have access to without leaving the app.',
  },
  {
    id: 'discovery',
    title: 'Automatic discovery',
    eyebrow: 'Zero config',
    body: 'Add a server, hit Discover. Tunnex runs <code>docker compose ls</code>, reads each service\'s image, queries Postgres / Mongo for their databases, and builds the tree. No manual yaml. No "what was the connection string again?"',
  },
  {
    id: 'backups',
    title: 'Backups, done right',
    eyebrow: 'Dumps',
    body: 'pg_dump custom format (-Fc) and mongodump archives, streamed straight out of the container over SSH. Adjustable compression (-Z 0…9). AES-256-GCM encryption on the fly — the dump never hits disk in cleartext.',
  },
  {
    id: 'restores',
    title: 'Restores you trust',
    eyebrow: 'Recovery',
    body: 'Pick a dump, pick a target database (same one or another), optional CLEAN before restore, preview the dump\'s metadata before clicking go. Tunnex routes the restore through the same SSH channel and shows live progress.',
  },
  {
    id: 'db-viewer',
    title: 'Live DB viewer',
    eyebrow: 'Inspect',
    body: 'Quick read-only browser for Postgres tables and Mongo collections. Paginated. Sortable. For when you just need to answer "is the row there?" without opening a separate IDE or SSH session.',
  },
  {
    id: 'encryption',
    title: 'Encryption model',
    eyebrow: 'Security',
    body: 'A 256-bit AES key is generated on first launch and stored in your OS keychain: Keychain on macOS, DPAPI on Windows, libsecret on Linux. The key is never written to a config file. Dumps are unusable on another machine without the same key — back up the key if you back up the dumps offsite.',
  },
  {
    id: 'updates',
    title: 'Background auto-updates',
    eyebrow: 'Always current',
    body: 'New version available? Tunnex downloads it in the background, then shows a non-blocking "Restart now / Later" banner. Skip the banner and it installs on next quit. Updates are pulled from the same R2 manifest that signed your install.',
  },
  {
    id: 'cross-platform',
    title: 'One binary, three OSes',
    eyebrow: 'Cross-platform',
    body: 'Native installers for Windows (NSIS with progress, shortcuts, uninstaller), macOS (DMG, x64 + arm64), and Linux (AppImage and .deb). Same workflow, same dump format, same encryption key portable between your machines.',
  },
];
---
<Base title="Product — Tunnex" description="Tunnex's feature deep-dive: discovery, dumps, restores, the live DB viewer, the encryption model, and how cross-platform auto-updates work.">
  <section class="hero-bg border-b border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto px-5 pt-20 pb-12 text-center">
      <p class="text-[var(--color-accent)] uppercase tracking-wider text-xs font-mono font-semibold mb-3">Product</p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight mb-4">Every feature, in depth.</h1>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
        Tunnex is small on purpose — eight ideas, executed well. Here's each one.
      </p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-5 py-20 space-y-24">
    {sections.map((s, i) => (
      <article id={s.id} class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div class:list={[i % 2 === 1 && 'lg:order-2']}>
          <p class="text-[var(--color-accent)] uppercase tracking-wider text-xs font-mono font-semibold mb-3">{s.eyebrow}</p>
          <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight mb-4">{s.title}</h2>
          <p class="text-lg text-[var(--color-text-muted)] leading-relaxed" set:html={s.body}></p>
          <a href={`/download#${s.id}`} class="mt-6 inline-flex items-center gap-2 text-sm text-[var(--color-accent)] hover:underline">
            Try it →
          </a>
        </div>
        <ScreenshotFrame alt={s.title}>
          <div class="text-xs font-mono text-[var(--color-text-faint)] p-12 text-center">
            <p class="text-[var(--color-text)] text-sm mb-2">{s.title}</p>
            <p>Place a screenshot at /screenshots/{s.id}.png</p>
          </div>
        </ScreenshotFrame>
      </article>
    ))}
  </div>

  <Section align="center">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight mb-4">See it on your own data.</h2>
      <p class="text-[var(--color-text-muted)] mb-6">Download takes 20 seconds. Adding your first server takes another 30.</p>
      <DownloadCTA compact />
    </div>
  </Section>
</Base>
